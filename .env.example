# ===== Database (Supabase Postgres or any standard Postgres) =====
# Supabase: Project Settings > Database > Connection string (use the "Session" pooler or direct connection)
# Any other host: a plain postgres:// connection string works the same way.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# ===== App =====
# Public base URL of the site (no trailing slash). Used for canonical URLs, sitemap, OG images.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Secret used to sign admin session tokens AND encrypt integration credentials.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_SECRET=change-me-to-a-64-char-hex-secret

# ===== Bootstrap admin (used once by `npm run setup`) =====
ADMIN_EMAIL=admin@doctorbondhu.com
ADMIN_PASSWORD=admin12345
ADMIN_NAME=Admin

# ===== Cloudflare R2 (image storage, S3-compatible) =====
# Cloudflare Dashboard > R2 > Create bucket, then "Manage R2 API Tokens" > Create API token
# R2_ACCOUNT_ID: Cloudflare dashboard sidebar (Account ID)
# R2_PUBLIC_URL: enable the bucket's public access (r2.dev subdomain) or attach a custom domain
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=doctorbondhu
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev
